# Twilio SMS — copy to .env in the project root for docker compose
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+12145550100
DISPATCHER_PHONE=+19454121215

# Optional: the public "Call Now" number, used in the customer's confirmation
# text. Defaults to the real main line already, so this only needs setting if
# that number ever changes.
BUSINESS_PHONE_DISPLAY=(945) 412-1215

# Optional: comma-separated origins allowed to call the API cross-origin from
# a browser (e.g. local dev with the frontend on :3000 and API on :3001).
# Same-origin calls through the nginx proxy don't need this at all.
ALLOWED_ORIGINS=http://localhost:3000

# Optional: abuse/cost protection for /api/request — every accepted request
# sends one real, billed SMS. Defaults shown below.
RATE_LIMIT_MAX_PER_IP=8
MAX_REQUESTS_PER_DAY=300
